# Supabase — copia este archivo a `.env.local` y rellena los valores.
# (Dashboard de Supabase → Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo se usa en el servidor (Server Actions / Route Handlers).
# NUNCA la expongas al cliente ni la commitees.
SUPABASE_SERVICE_ROLE_KEY=
