# Supabase — copia este archivo a `.env` (o `.env.local`) y rellena los valores.
# Dashboard de Supabase → Project Settings → API Keys (llaves nuevas).

NEXT_PUBLIC_SUPABASE_URL=
# Llave "publishable" (pública, segura en el navegador). Formato: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Llave "secret" (privada). Solo en el servidor (Server Actions / Route Handlers).
# NUNCA con prefijo NEXT_PUBLIC ni la commitees. Formato: sb_secret_...
SUPABASE_SECRET_KEY=

# ── Mercado Pago (pagos) ────────────────────────────────────────────────────
# Pon "true" para activar el pago con Mercado Pago en el checkout.
NEXT_PUBLIC_MP_ENABLED=
# Access Token de Mercado Pago (privado, solo servidor). Usa el del VENDEDOR de
# prueba para testear (ver docs/PROBAR-PAGOS.md). Formato: APP_USR-... o TEST-...
MP_ACCESS_TOKEN=

# ── Identidad de la tienda (centralizado en app/lib/config.ts) ───────────────
# Personaliza la plantilla sin tocar componentes. Si se dejan vacías, config.ts
# usa los valores por defecto.
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_SITE_TAGLINE=
NEXT_PUBLIC_SITE_DESCRIPTION=

# ── Moneda y formato ────────────────────────────────────────────────────────
# Código ISO (ARS, COP, MXN, CLP, PEN…) y locale (es-AR, es-CO, es-MX…).
NEXT_PUBLIC_CURRENCY=
NEXT_PUBLIC_LOCALE=
